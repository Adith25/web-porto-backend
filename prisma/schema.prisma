generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  techStack   String
  icon        String?
  githubUrl   String?
  demoUrl     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Experience {
  id          Int      @id @default(autoincrement())
  role        String
  company     String
  position    String?
  period      String
  location    String?
  logo        String?
  description String   @default("")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Skill {
  id        Int      @id @default(autoincrement())
  category  String
  icon      String?
  items     String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Model untuk menyimpan data Admin yang bisa login
model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// Model untuk menyimpan data Sertifikat portofolio
model Certificate {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?
  credentialUrl String?
  fileUrl       String?
  isPdf         Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
}

// Model untuk menyimpan data About Me card
model AboutCard {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  icon      String?
  textColor String   @default("text-gray-600 dark:text-gray-400")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Model untuk menyimpan pengaturan umum website seperti Announcement Banner
model SiteSetting {
  id                 Int      @id @default(1)
  announcementText   String   @default("⚠️ This website is still under development ⚠️")
  announcementActive Boolean  @default(true)
  bannerColor        String   @default("#4f46e5") // indigo-600
  textColor          String   @default("#ffffff") // white
  animationSpeed     Int      @default(25)        // seconds
  updatedAt          DateTime @updatedAt
}