generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  techStack   String
  githubUrl   String?
  demoUrl     String?
  createdAt   DateTime @default(now())
  icon        String?
  order       Int      @default(0)
}

model Experience {
  id          Int      @id @default(autoincrement())
  role        String
  company     String
  period      String
  location    String?
  logo        String?
  createdAt   DateTime @default(now())
  order       Int      @default(0)
  description String   @default("")
  position    String?
}

model Skill {
  id        Int      @id @default(autoincrement())
  category  String
  icon      String?
  items     String   @default("")
  createdAt DateTime @default(now())
  order     Int      @default(0)
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Certificate {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?
  credentialUrl String?
  fileUrl       String?
  isPdf         Boolean  @default(false)
  createdAt     DateTime @default(now())
  order         Int      @default(0)
  pdfUrl        String?
}

model AboutCard {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  icon      String?
  textColor String   @default("text-gray-600 dark:text-gray-400")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model SiteSetting {
  id                 Int      @id @default(1)
  announcementText   String   @default("⚠️ This website is still under development ⚠️")
  announcementActive Boolean  @default(true)
  bannerColor        String   @default("#4f46e5")
  textColor          String   @default("#ffffff")
  animationSpeed     Int      @default(25)
  cvUrl              String?
  updatedAt          DateTime @updatedAt
}

model CV {
  id         Int      @id @default(autoincrement())
  fileName   String
  fileUrl    String   @unique
  fileSize   Int
  mimeType   String   @default("application/pdf")
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
}
