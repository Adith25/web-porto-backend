generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  techStack   String
  icon        String?
  githubUrl   String?
  demoUrl     String?
  createdAt   DateTime @default(now())
}

model Experience {
  id        Int      @id @default(autoincrement())
  role      String
  company   String
  period    String
  location  String?
  logo      String?
  tech      String   @default("")
  createdAt DateTime @default(now())
}

model Skill {
  id        Int      @id @default(autoincrement())
  category  String
  icon      String?
  items     String   @default("")
  createdAt DateTime @default(now())
}

// Model untuk menyimpan data Admin yang bisa login
model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// Model untuk menyimpan data Sertifikat portofolio
model Certificate {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?
  credentialUrl String?
  fileUrl       String?
  isPdf         Boolean  @default(false)
  createdAt     DateTime @default(now())
}